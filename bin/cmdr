#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Bash version guard — requires 4.3+ for declare -A and local -n (namerefs).
# macOS ships bash 3.2 by default; install a modern version via:
#   brew install bash
# ---------------------------------------------------------------------------
if [[ "${BASH_VERSINFO[0]}" -lt 4 ]] || \
   { [[ "${BASH_VERSINFO[0]}" -eq 4 ]] && [[ "${BASH_VERSINFO[1]}" -lt 3 ]]; }; then
    echo "cmdr requires bash >= 4.3 (you have ${BASH_VERSION})." >&2
    echo "macOS: brew install bash" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Resolve the real directory of this script, following symlinks.
# Uses plain readlink (one level at a time) — readlink -f and realpath are absent on macOS BSD tools.
# ---------------------------------------------------------------------------
cmdr::real_dir() {
    local src="${BASH_SOURCE[0]}" dir
    while [[ -L "$src" ]]; do
        dir="$(cd -P "$(dirname "$src")" && pwd)"
        src="$(readlink "$src")"
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    cd -P "$(dirname "$src")" && pwd
}
_CMDR_SELF_DIR="$(cmdr::real_dir)"

source "$_CMDR_SELF_DIR/../src/core/cmdr.sh"

cmdr::bootstrap "$@"
cmdr::dispatch "${_CMDR_REMAINING_ARGS[@]+"${_CMDR_REMAINING_ARGS[@]}"}"
